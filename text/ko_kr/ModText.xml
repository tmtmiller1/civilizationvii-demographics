        <Replace Tag="LOC_DEMOGRAPHICS_TITLE" Language="ko_KR"><Text>인구 통계</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_SUBTITLE" Language="ko_KR"><Text>시간에 따른 점수</Text></Replace>
