<?xml version="1.0" encoding="utf-8"?>
<Database>
    <LocalizedText>
        <Replace Tag="LOC_MOD_DEMOGRAPHICS_NAME" Language="zh_Hans_CN">
            <Text>人口统计</Text>
        </Replace>
        <Replace Tag="LOC_MOD_DEMOGRAPHICS_DESCRIPTION" Language="zh_Hans_CN">
            <Text>每回合历史图表、世界年鉴、全球关系环、冲突甘特图，以及每个已遇文明的原生成就进度条。</Text>
        </Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_OPEN" Language="zh_Hans_CN">
            <Text>人口统计</Text>
        </Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_TITLE" Language="zh_Hans_CN">
            <Text>人口统计</Text>
        </Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_SUBTITLE" Language="zh_Hans_CN">
            <Text>分数随时间变化</Text>
        </Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_FOOTNOTE" Language="zh_Hans_CN">
            <Text>采样器实时历史。</Text>
        </Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_CLOSE" Language="zh_Hans_CN">
            <Text>关闭</Text>
        </Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_BODY" Language="zh_Hans_CN">
            <Text>你好。如果你能看到这句话，系统正常。</Text>
        </Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_SCORE" Language="zh_Hans_CN">
            <Text>分数</Text>
        </Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_GOLD" Language="zh_Hans_CN">
            <Text>金库</Text>
        </Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_GPT" Language="zh_Hans_CN">
            <Text>每回合金币</Text>
        </Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_GPT_TOOLTIP" Language="zh_Hans_CN">
            <Text>每回合净金币收入。</Text>
        </Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_SETTLEMENTS" Language="zh_Hans_CN">
            <Text>定居点</Text>
        </Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_TECHS" Language="zh_Hans_CN">
            <Text>科技</Text>
        </Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_CIVICS" Language="zh_Hans_CN">
            <Text>公民</Text>
        </Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_SCORE_TOOLTIP" Language="zh_Hans_CN">
            <Text>综合实力分数，与胜利界面一致。</Text>
        </Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_GOLD_TOOLTIP" Language="zh_Hans_CN">
            <Text>当前金库余额。</Text>
        </Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_SETTLEMENTS_TOOLTIP" Language="zh_Hans_CN">
            <Text>拥有的城市和城镇总数。</Text>
        </Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_TECHS_TOOLTIP" Language="zh_Hans_CN">
            <Text>拥有的科技总数。</Text>
        </Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_CIVICS_TOOLTIP" Language="zh_Hans_CN">
            <Text>拥有的公民总数。</Text>
        </Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_GDP" Language="zh_Hans_CN">
            <Text>GDP</Text>
        </Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_GDP_TOOLTIP" Language="zh_Hans_CN">
            <Text>伪真实国内生产总值。按各回合产出加权求和（生产力 1.0、金币 1.0、科学 1.2、文化 1.2、食物 0.5、影响力 1.5），乘以已经过的回合数并换算为美元。</Text>
        </Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_PRODUCTION" Language="zh_Hans_CN">
            <Text>每回合生产力</Text>
        </Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_PRODUCTION_TOOLTIP" Language="zh_Hans_CN">
            <Text>每回合生产力——你的城市所建造的产出。</Text>
        </Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_SCIENCE_YIELD" Language="zh_Hans_CN">
            <Text>科学</Text>
        </Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_SCIENCE_YIELD_TOOLTIP" Language="zh_Hans_CN">
            <Text>每回合科学——推动科技研究。</Text>
        </Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_CULTURE_YIELD" Language="zh_Hans_CN">
            <Text>文化</Text>
        </Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_CULTURE_YIELD_TOOLTIP" Language="zh_Hans_CN">
            <Text>每回合文化——推动公民进度。</Text>
        </Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_CROPS" Language="zh_Hans_CN">
            <Text>作物产量</Text>
        </Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_CROPS_TOOLTIP" Language="zh_Hans_CN">
            <Text>所有定居点每回合的净食物产出。</Text>
        </Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_APPROVAL" Language="zh_Hans_CN">
            <Text>外交支持度</Text>
        </Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_APPROVAL_TOOLTIP" Language="zh_Hans_CN">
            <Text>国际声誉总和。对所有已遇主要文明的加权关系分数求和（结盟 +5、有益 +3、友好 +2、中立 0、不友好 -2、敌对 -3、交战 -5），再加上你担任宗主的城邦的衰减（0.3 倍）贡献。</Text>
        </Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_POPULATION" Language="zh_Hans_CN">
            <Text>人口</Text>
        </Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_POPULATION_TOOLTIP" Language="zh_Hans_CN">
            <Text>按比例换算的现实世界人口，由公民总数以指数方式推算得出。</Text>
        </Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_INFLUENCE" Language="zh_Hans_CN">
            <Text>每回合影响力</Text>
        </Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_HPT" Language="zh_Hans_CN">
            <Text>每回合幸福度</Text>
        </Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_HPT_TOOLTIP" Language="zh_Hans_CN">
            <Text>每回合净幸福度产出。</Text>
        </Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_INFLUENCE_TOOLTIP" Language="zh_Hans_CN">
            <Text>每回合产生的净外交影响力。</Text>
        </Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_DEALS" Language="zh_Hans_CN">
            <Text>进行中的协议</Text>
        </Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_DEALS_TOOLTIP" Language="zh_Hans_CN">
            <Text>涉及该领袖的活跃外交行动、事业、制裁和间谍活动。</Text>
        </Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_TRADE" Language="zh_Hans_CN">
            <Text>贸易路线</Text>
        </Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_TRADE_TOOLTIP" Language="zh_Hans_CN">
            <Text>从该玩家城市出发的活跃贸易路线数量。</Text>
        </Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_LAND" Language="zh_Hans_CN">
            <Text>陆地面积</Text>
        </Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_LAND_TOOLTIP" Language="zh_Hans_CN">
            <Text>拥有的领土总面积（平方公里），由所控制的六边形地块换算而来。</Text>
        </Replace>
