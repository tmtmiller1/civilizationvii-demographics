        <!-- Unmet placeholder strings (Fix 4) -->
        <Row Tag="LOC_DEMOGRAPHICS_UNMET_CIV">
            <Text>Unmet Civilization</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_UNMET_CIV_TOOLTIP">
            <Text>You have not yet met this civilization. Enable "Show names of unmet civilizations and city-states" in Options to reveal real names.</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_UNMET_CS">
            <Text>Unmet City State</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_UNMET_CS_TOOLTIP">
            <Text>You have not yet met this city-state. Enable "Show names of unmet civilizations and city-states" in Options to reveal real names.</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_OPT_SHOW_UNMET_NAMES">
            <Text>Show names of unmet civilizations and city-states</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_OPT_SHOW_UNMET_NAMES_TOOLTIP">
            <Text>When off (default), civs and city-states you have not yet met are shown as generic "Unmet" placeholders in charts, the factbook, and global relations rings.</Text>
        </Row>

    </EnglishText>
</Database>
