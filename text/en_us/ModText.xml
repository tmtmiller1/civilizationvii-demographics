<?xml version="1.0" encoding="utf-8"?>
<Database>
    <EnglishText>
        <Row Tag="LOC_MOD_DEMOGRAPHICS_NAME">
            <Text>Demographics</Text>
        </Row>
        <Row Tag="LOC_MOD_DEMOGRAPHICS_DESCRIPTION">
            <Text>Per-turn historical graphs, world factbook, global relations rings, conflicts gantt, and native-Triumphs progress bars for every met civilization.</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_OPEN">
            <Text>Demographics</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_TITLE">
            <Text>Demographics</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_SUBTITLE">
            <Text>Score over time</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_FOOTNOTE">
            <Text>Live history from the sampler.</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_CLOSE">
            <Text>Close</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_BODY">
            <Text>Hello. If you can read this, the harness works.</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_METRIC_SCORE">
            <Text>Score</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_METRIC_GOLD">
            <Text>Treasury</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_METRIC_GPT">
            <Text>GPT</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_METRIC_GPT_TOOLTIP">
            <Text>Gold income per turn (net).</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_METRIC_SETTLEMENTS">
            <Text>Settlements</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_METRIC_TECHS">
            <Text>Techs</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_METRIC_CIVICS">
            <Text>Civics</Text>
        </Row>

        <!-- Tooltips for the original 5 metrics -->
        <Row Tag="LOC_DEMOGRAPHICS_METRIC_SCORE_TOOLTIP">
            <Text>Composite power score, the same number the Victory screen uses.</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_METRIC_GOLD_TOOLTIP">
            <Text>Current treasury balance.</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_METRIC_SETTLEMENTS_TOOLTIP">
            <Text>Total number of cities and towns owned.</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_METRIC_TECHS_TOOLTIP">
            <Text>Number of fully-researched technology nodes in the current age tree.</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_METRIC_CIVICS_TOOLTIP">
            <Text>Number of fully-unlocked civic nodes in the current age tree.</Text>
        </Row>

        <!-- V5 pseudo-realistic -->
        <Row Tag="LOC_DEMOGRAPHICS_METRIC_GDP">
            <Text>GDP</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_METRIC_GDP_TOOLTIP">
            <Text>Pseudo-realistic gross domestic product. Weighted sum of per-turn yields (Production 1.0, Gold 1.0, Science 1.2, Culture 1.2, Food 0.5, Influence 1.5), multiplied by turns elapsed and scaled to dollars.</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_METRIC_PRODUCTION">
            <Text>PPT</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_METRIC_PRODUCTION_TOOLTIP">
            <Text>Production per turn — what your cities build.</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_METRIC_SCIENCE_YIELD">
            <Text>Science</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_METRIC_SCIENCE_YIELD_TOOLTIP">
            <Text>Science per turn — drives technology research.</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_METRIC_CULTURE_YIELD">
            <Text>Culture</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_METRIC_CULTURE_YIELD_TOOLTIP">
            <Text>Culture per turn — drives civics progress.</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_METRIC_CROPS">
            <Text>Crop Yield</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_METRIC_CROPS_TOOLTIP">
            <Text>Net food output per turn across all settlements.</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_METRIC_APPROVAL">
            <Text>Diplomatic Approval</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_METRIC_APPROVAL_TOOLTIP">
            <Text>International reputation aggregate. Sum of weighted relationship scores across all met major civs (Allied +5, Helpful +3, Friendly +2, Neutral 0, Unfriendly -2, Hostile -3, At War -5) plus a damped (0.3x) contribution from city-states where you are suzerain.</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_METRIC_POPULATION">
            <Text>Population</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_METRIC_POPULATION_TOOLTIP">
            <Text>Scaled real-world population, exponentially derived from total citizen count.</Text>
        </Row>

        <!-- V7-specific creative -->
        <Row Tag="LOC_DEMOGRAPHICS_METRIC_INFLUENCE">
            <Text>IPT</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_METRIC_HPT">
            <Text>HPT</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_METRIC_HPT_TOOLTIP">
            <Text>Net happiness yield per turn.</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_METRIC_INFLUENCE_TOOLTIP">
            <Text>Net diplomatic Influence generated per turn.</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_METRIC_DEALS">
            <Text>Ongoing Deals</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_METRIC_DEALS_TOOLTIP">
            <Text>Active diplomatic actions, endeavors, sanctions, and espionage involving this leader.</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_METRIC_TRADE">
            <Text>Trade Routes</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_METRIC_TRADE_TOOLTIP">
            <Text>Number of active trade routes leaving this player's cities.</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_METRIC_LAND">
            <Text>Land Area</Text>
        </Row>
        <Row Tag="LOC_DEMOGRAPHICS_METRIC_LAND_TOOLTIP">
            <Text>Total territory owned in square kilometers, scaled from controlled hex tiles.</Text>
        </Row>

