<?xml version="1.0" encoding="utf-8"?>
<Database>
    <LocalizedText>
        <Replace Tag="LOC_MOD_DEMOGRAPHICS_NAME" Language="it_IT"><Text>Demografia</Text></Replace>
        <Replace Tag="LOC_MOD_DEMOGRAPHICS_DESCRIPTION" Language="it_IT"><Text>Grafici storici per turno, factbook mondiale, anelli delle relazioni globali, diagramma di Gantt dei conflitti e barre di avanzamento dei Trionfi nativi per ogni civiltà incontrata.</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_OPEN" Language="it_IT"><Text>Demografia</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_TITLE" Language="it_IT"><Text>Demografia</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_SUBTITLE" Language="it_IT"><Text>Punteggio nel tempo</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_FOOTNOTE" Language="it_IT"><Text>Cronologia in tempo reale dal campionatore.</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_CLOSE" Language="it_IT"><Text>Chiudi</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_BODY" Language="it_IT"><Text>Salve. Se riesci a leggere questo, l'impalcatura funziona.</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_SCORE" Language="it_IT"><Text>Punteggio</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_GOLD" Language="it_IT"><Text>Tesoro</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_GPT" Language="it_IT"><Text>GPT</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_GPT_TOOLTIP" Language="it_IT"><Text>Entrate d'oro per turno (nette).</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_SETTLEMENTS" Language="it_IT"><Text>Insediamenti</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_TECHS" Language="it_IT"><Text>Tecnologie</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_CIVICS" Language="it_IT"><Text>Civismi</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_SCORE_TOOLTIP" Language="it_IT"><Text>Punteggio di potenza composito, lo stesso numero usato dalla schermata della Vittoria.</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_GOLD_TOOLTIP" Language="it_IT"><Text>Saldo attuale del tesoro.</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_SETTLEMENTS_TOOLTIP" Language="it_IT"><Text>Numero totale di città e villaggi posseduti.</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_TECHS_TOOLTIP" Language="it_IT"><Text>Numero di nodi tecnologici completamente ricercati nell'albero dell'era attuale.</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_CIVICS_TOOLTIP" Language="it_IT"><Text>Numero di nodi civici completamente sbloccati nell'albero dell'era attuale.</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_GDP" Language="it_IT"><Text>PIL</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_GDP_TOOLTIP" Language="it_IT"><Text>Prodotto interno lordo pseudo-realistico. Somma ponderata dei rendimenti per turno (Produzione 1.0, Oro 1.0, Scienza 1.2, Cultura 1.2, Cibo 0.5, Influenza 1.5), moltiplicata per i turni trascorsi e scalata in dollari.</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_PRODUCTION" Language="it_IT"><Text>PPT</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_PRODUCTION_TOOLTIP" Language="it_IT"><Text>Produzione per turno — ciò che costruiscono le tue città.</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_SCIENCE_YIELD" Language="it_IT"><Text>Scienza</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_SCIENCE_YIELD_TOOLTIP" Language="it_IT"><Text>Scienza per turno — alimenta la ricerca tecnologica.</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_CULTURE_YIELD" Language="it_IT"><Text>Cultura</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_CULTURE_YIELD_TOOLTIP" Language="it_IT"><Text>Cultura per turno — alimenta i progressi dei civismi.</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_CROPS" Language="it_IT"><Text>Resa agricola</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_CROPS_TOOLTIP" Language="it_IT"><Text>Produzione netta di cibo per turno in tutti gli insediamenti.</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_APPROVAL" Language="it_IT"><Text>Approvazione diplomatica</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_APPROVAL_TOOLTIP" Language="it_IT"><Text>Aggregato della reputazione internazionale. Somma dei punteggi di relazione ponderati di tutte le civiltà maggiori incontrate (Alleata +5, Disponibile +3, Amichevole +2, Neutrale 0, Ostile -2, Bellicosa -3, In guerra -5) più un contributo smorzato (0,3x) dalle città-stato di cui sei signore supremo.</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_POPULATION" Language="it_IT"><Text>Popolazione</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_POPULATION_TOOLTIP" Language="it_IT"><Text>Popolazione reale scalata, derivata esponenzialmente dal numero totale di cittadini.</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_INFLUENCE" Language="it_IT"><Text>IPT</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_HPT" Language="it_IT"><Text>HPT</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_HPT_TOOLTIP" Language="it_IT"><Text>Resa netta di felicità per turno.</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_INFLUENCE_TOOLTIP" Language="it_IT"><Text>Influenza diplomatica netta generata per turno.</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_DEALS" Language="it_IT"><Text>Accordi in corso</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_DEALS_TOOLTIP" Language="it_IT"><Text>Azioni diplomatiche, iniziative, sanzioni e spionaggio attivi che coinvolgono questo leader.</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_TRADE" Language="it_IT"><Text>Rotte commerciali</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_TRADE_TOOLTIP" Language="it_IT"><Text>Numero di rotte commerciali attive in partenza dalle città di questo giocatore.</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_LAND" Language="it_IT"><Text>Superficie territoriale</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_METRIC_LAND_TOOLTIP" Language="it_IT"><Text>Territorio totale posseduto in chilometri quadrati, scalato dalle caselle esagonali controllate.</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_TAB_HISTORY" Language="it_IT"><Text>Dati storici</Text></Replace>
        <Replace Tag="LOC_DEMOGRAPHICS_TAB_FACTBOOK" Language="it_IT"><Text>Factbook mondiale</Text></Replace>
